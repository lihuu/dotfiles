# 复制为 .env 后按需修改。

HOMEBREW_PREFIX=

# 这次改造后，Prometheus / Alertmanager / Grafana 通过 docker compose 部署。
# 下面的地址控制宿主机端口暴露到哪些网卡。作为局域网中央监控，默认开放到所有网卡。
STACK_BIND_ADDRESS=0.0.0.0

PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_RETENTION_TIME=7d
PROMETHEUS_RETENTION_SIZE=8GB

ALERTMANAGER_PORT=9093

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# docker image 可按需固定版本。
PROMETHEUS_IMAGE=prom/prometheus:v3.10.0
ALERTMANAGER_IMAGE=prom/alertmanager:v0.31.1
GRAFANA_IMAGE=grafana/grafana:12.4.0
COMPOSE_PROJECT_NAME=macos-monitoring

# 宿主机 node_exporter 保持通过 Homebrew 运行。
# 为了让容器内 Prometheus 能抓到当前这台 Mac，node_exporter 默认要监听 0.0.0.0。
NODE_EXPORTER_LISTEN_ADDRESS=0.0.0.0
NODE_EXPORTER_PORT=9100
TEXTFILE_COLLECTOR_DIR=

# 优先使用 webhook 对接 Telegram bridge。
ALERT_WEBHOOK_URL=

# 如果没有 webhook bridge，但有 Telegram Bot，可以改用原生 telegram_configs。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

CPU_ALERT_THRESHOLD=80
MEM_ALERT_THRESHOLD=85
DISK_ALERT_THRESHOLD=15
