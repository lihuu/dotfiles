# 复制为 .env 后按需修改。

HOMEBREW_PREFIX=

PROMETHEUS_LISTEN_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_STORAGE_PATH=

NODE_EXPORTER_LISTEN_ADDRESS=127.0.0.1
NODE_EXPORTER_PORT=9100
TEXTFILE_COLLECTOR_DIR=

ALERTMANAGER_LISTEN_ADDRESS=127.0.0.1
ALERTMANAGER_PORT=9093
ALERTMANAGER_STORAGE_PATH=

GRAFANA_LISTEN_ADDRESS=127.0.0.1
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_DATA_PATH=
GRAFANA_LOG_PATH=
GRAFANA_DASHBOARDS_DEST=

# 优先使用 webhook 对接 Telegram bridge。
# 如果你已经有 Telegram webhook bridge，把它填到这里。
ALERT_WEBHOOK_URL=

# 保留 Telegram 模板变量，便于后续切换到 Alertmanager 原生 telegram_configs
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

CPU_ALERT_THRESHOLD=80
MEM_ALERT_THRESHOLD=85
DISK_ALERT_THRESHOLD=15
